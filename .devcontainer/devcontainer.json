{
  "name": "Odysseus Dev",
  "dockerComposeFile": ["../docker-compose.yml", "docker-compose.yml"],
  "service": "odysseus",
  "workspaceFolder": "/app",
  "forwardPorts": [7000, 8080, 8100, 8091],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy",
        "batisteo.vscode-django",
        "bradlc.vscode-tailwindcss"
      ]
    }
  },
  "postCreateCommand": "pip install -r requirements.txt 2>/dev/null || true",
  "remoteUser": "odysseus"
}
